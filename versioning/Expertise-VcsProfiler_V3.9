CONFIG_YAML:

```yaml
# ═══════════════════════════════════════════════════════════════════════════════
# SECÇÃO 1 — MSISDN PREFIX RULES
# ═══════════════════════════════════════════════════════════════════════════════

  msisdn_prefix_rules:
    global_rule:
      ensure_351_prefix_always: true
    rules:
      - name: rule_9_digits_start_9_or_2
        condition: { length: 9, starts_with_any: ["9", "2"] }
        action: { prepend: "351" }
        result_length: 12
      - name: rule_12_digits_start_49
        condition: { length: 12, starts_with: "49" }
        action: { prepend: "351" }
        result_length: 15
        classification: "iot_m2m"
      - name: rule_15_digits_start_35149
        condition: { length: 15, starts_with: "35149" }
        action: { none: true }
        result_length: 15
        classification: "iot_m2m"


# ═══════════════════════════════════════════════════════════════════════════════
# SECÇÃO 2 — PRÉ-PROCESSAMENTO (PRE-1 a PRE-4)
# ═══════════════════════════════════════════════════════════════════════════════

  pre_processing_steps:

    hard_gate:
      tool_call_order:
        1: "FGNTP — portabilidade (gate bloqueante)"
        2: "eNUM — componente IMS"
        3: "HGSDP_Perfil e restantes tools (apenas após NOS confirmado)"
      blocked_tools_before_fgntp:
        - "HGSDP_Perfil"
        - "MTAS"
        - "HSS"
        - "HssSubscriberProfile"
        - "getAuthSubscription"
        - "GetEpcUdmSubscription"
        - "SubsInfoByIMPU"
        - "BwGetUserInfo"

    steps:

      - id: PRE1_NUMBER_CLASSIFICATION
        always_execute: true
        number_types:
          fixed_geographic:
            pattern: "9 dígitos iniciados em 2xx"
            sub_types:
              - { prefix: "21x", area: "Lisboa e Setúbal" }
              - { prefix: "22x", area: "Porto e Norte" }
              - { prefix: "23x–28x", area: "Regiões de Portugal Continental" }
              - { prefix: "291", area: "Madeira" }
              - { prefix: "292 / 295 / 296", area: "Açores" }
            normalize: "prepend 351 → 12 dígitos E.164"
            classification: "fixed_geographic"
          mobile:
            pattern: "9 dígitos iniciados em 9xx"
            sub_types:
              - { prefix: "91x", operator_origin: "Vodafone" }
              - { prefix: "92x", operator_origin: "NOS" }
              - { prefix: "93x", operator_origin: "NOS" }
              - { prefix: "95x", operator_origin: "NOS (gama adicional)" }
              - { prefix: "96x", operator_origin: "MEO" }
            normalize: "prepend 351 → 12 dígitos E.164"
            classification: "mobile"
          special:
            pattern: "800 | 808 | 707 | 760 | 761"
            classification: "special"
          non_geographic_ip:
            pattern: "300–309"
            classification: "non_geographic_ip"
          iot_m2m:
            patterns:
              - { format: "12 dígitos iniciados em 49x", action: "prepend 351 → 15 dígitos" }
              - { format: "15 dígitos iniciados em 35149x", action: "já normalizado" }
            classification: "iot_m2m"
        invalid_input:
          action: "Rejeitar. Informar utilizador. FIM."

      - id: PRE2_PORTABILITY_FGNTP
        always_execute: true
        tool: "FGNTP"
        execution_type: "EXPLICIT_TOOL_CALL — primeira tool call"
        priority: "ABSOLUTA — sem excepções"
        decision_logic:
          fnr_not_defined:
            native_prefix_rules:
              - { prefix: "35192x / 35193x / 35195x", operator: "NOS", action: "Continuar para PRE-3" }
              - { prefix: "35191x", operator: "Vodafone", action: "⛔ STOP — FIM ABSOLUTO" }
              - { prefix: "35196x", operator: "MEO", action: "⛔ STOP — FIM ABSOLUTO" }
          nprefix_present:
            rules:
              - { nprefix: "093777", operator: "NOS", direction: "ported_in", action: "Continuar para PRE-3" }
              - { nprefix: "091XXX", operator: "Vodafone", direction: "ported_out", action: "⛔ STOP — FIM ABSOLUTO" }
              - { nprefix: "096XXX", operator: "MEO", direction: "ported_out", action: "⛔ STOP — FIM ABSOLUTO" }
              - { nprefix: "outros", action: "⛔ STOP — FIM ABSOLUTO" }
        stop_action:
          response_format: "NPREFIX: [código] | Operador Destino: [nome]. Análise técnica não permitida."
          next_step: "NENHUM. FIM ABSOLUTO."
        scope:
          applies_to_all_types: true
          no_exceptions: true

      - id: PRE3_ENUM_IMS_CHECK
        always_execute: true
        tool: "eNUM"
        execution_type: "EXPLICIT_TOOL_CALL — segunda tool call"
        parse_field: "naptrTxt"
        result_rules:
          - id: "PATTERN_A_STANDARD_IMS"
            response_pattern: "naptrTxt contém 'msisdn@<domínio>'"
            applicable_to: ["fixed_geographic", "mobile"]
            register: "IMS_STATUS = ACTIVE"
            meaning: "IMS standard. Mobile: pode ser VoLTE ou Mobile Centrex — distinguir no STEP 4."
          - id: "PATTERN_B_CENTREX_IMS"
            response_pattern: "naptrTxt contém 'sip:' E '@ipcentrex.ims.nos.pt'"
            example: "!^.*$!sip:3512xxxxxxxx@ipcentrex.ims.nos.pt!"
            applicable_to: ["fixed_geographic"]
            register: "IMS_STATUS = ACTIVE_CENTREX"
            note: "Home Centrex vs Centrex puro → STEP 1 (HGSDP_Perfil)."
          - id: "PATTERN_C_IMS_ABSENT"
            response_pattern: "SUBSCRIPTION NOT DEFINED ou naptrTxt ausente"
            applicable_to: ["fixed_geographic", "mobile"]
            register: "IMS_STATUS = ABSENT"
          - id: "PATTERN_D_IOT"
            response_pattern: "SUBSCRIPTION NOT DEFINED ou sem resposta"
            applicable_to: ["iot_m2m"]
            register: "IMS_STATUS = NOT_APPLICABLE"
            is_misconfiguration: false
          - id: "PATTERN_E_3GPP_NOS_DOMAIN"
            response_pattern: "naptrTxt contém 'sip:' E '@ims.mnc003.mcc268.3gppnetwork.org'"
            example: "sip:+351930428319@ims.mnc003.mcc268.3gppnetwork.org"
            applicable_to: ["mobile", "fixed_geographic"]
            register: "IMS_STATUS = ACTIVE"
            meaning: >
              IMS activo com domínio 3GPP standard para NOS Portugal (MCC=268, MNC=003).
              Mobile: pode ser VoLTE ou Mobile Centrex — distinguir no STEP 4 via IMPI e Service Profile.
        discrimination_rules:
          - "PATTERN_A vs PATTERN_E: ambos registam ACTIVE. Distinção VoLTE vs Mobile Centrex no STEP 4."
          - "PATTERN_A vs PATTERN_B: '@ipcentrex.ims.nos.pt' → PATTERN_B (fixo). 'msisdn@' → PATTERN_A."
          - "PATTERN_C vs PATTERN_D: distinção pela classificação PRE-1."
        no_response_fallback:
          voice_fixed: "IMS_STATUS = ABSENT"
          iot_m2m: "IMS_STATUS = NOT_APPLICABLE"

      - id: PRE4_SOLUTION_PRE_IDENTIFICATION
        always_execute: true
        note: >
          ACTIVE_CENTREX (fixo) → indeterminado até STEP 1.
          ACTIVE (móvel) → PRELIMINAR = NOS Mobile VoLTE.
          Reclassificação para NOS Mobile Centrex ocorre no STEP 4.
        logic:
          - { type: "iot_m2m", ims_status: "NOT_APPLICABLE", solution: "NOS IoT / Banda Larga Dados", platform: "LTE / NB-IoT / LTE-M / PS Data", steps_not_applicable: ["STEP2_MTAS", "STEP2B_getAuthSubscription", "STEP2C_GetEpcUdmSubscription", "STEP5_SubsInfoByIMPU", "STEP6_BwGetUserInfo"] }
          - { type: "fixed_geographic", ims_status: "ACTIVE_CENTREX", solution: "NOS Centrex (indeterminado)", platform: "IMS IP Centrex (ipcentrex.ims.nos.pt)", steps_not_applicable: ["STEP2_MTAS", "STEP2B_getAuthSubscription", "STEP2C_GetEpcUdmSubscription"] }
          - { type: "fixed_geographic", ims_status: "ACTIVE", solution: "NOS Fixed IMS", platform: "FTTH / HFC / Ericsson IMS", steps_not_applicable: ["STEP2_MTAS", "STEP2B_getAuthSubscription", "STEP2C_GetEpcUdmSubscription"] }
          - { type: "fixed_geographic", ims_status: "ABSENT", solution: "NOS Fixed Legacy / BroadSoft", platform: "PSTN / DSL / BroadSoft XSP", steps_not_applicable: ["STEP2_MTAS", "STEP2B_getAuthSubscription", "STEP2C_GetEpcUdmSubscription"] }
          - { type: "mobile", ims_status: "ACTIVE", solution: "NOS Mobile VoLTE (PRELIMINAR — verificar STEP 4 para Mobile Centrex)", platform: "4G LTE / 5G NR" }
          - { type: "mobile", ims_status: "ABSENT", solution: "NOS Mobile CS", platform: "2G GSM / 4G CSFB" }
          - { type: "special", solution: "NOS Special Service", platform: "IN Platform / IMS TAS" }
          - { type: "non_geographic_ip", solution: "NOS Non-Geographic VoIP", platform: "IMS / SBC Empresarial" }


# ═══════════════════════════════════════════════════════════════════════════════
# SECÇÃO 3 — CORRELAÇÕES eNUM × STEP 4 e STEP 1
# ═══════════════════════════════════════════════════════════════════════════════

  enum_correlations:

    with_step4_HssSubscriberProfile:
      voice_and_fixed_standard:
        - { ims_status: "ACTIVE", step4_result: "profile_found", outcome: "CONFIRMED_IMS_ACTIVE", note: "Verificar IMPI e Service Profile para distinguir VoLTE de Mobile Centrex." }
        - { ims_status: "ACTIVE", step4_result: "no_profile", outcome: "MISCONFIGURATION", flag: "eNUM indica IMS activo mas HssSubscriberProfile ausente" }
        - { ims_status: "ABSENT", step4_result: "profile_found", outcome: "MISCONFIGURATION", flag: "HssSubscriberProfile tem perfil mas eNUM não configurado" }
        - { ims_status: "ABSENT", step4_result: "no_profile", outcome: "CONFIRMED_CS_LEGACY" }

      mobile_centrex_reclassification:
        - condition: "IMPI contém '@ipcentrex.ims.nos.pt' OU Service Profile = 'BW_MobileCentrex_Active'"
          outcome: "RECLASSIFIED_MOBILE_CENTREX"
          solution: "NOS Mobile Centrex"
          action: "Reclassificar. Executar STEP 6 — esperar PadraoMovel activo."
        - condition: "IMPI NÃO contém '@ipcentrex.ims.nos.pt' E Service Profile ≠ 'BW_MobileCentrex_Active'"
          outcome: "CONFIRMED_MOBILE_VOLTE"
          solution: "NOS Mobile VoLTE"

      centrex_fixed:
        - { ims_status: "ACTIVE_CENTREX", step4_result: "profile_found", outcome: "CONFIRMED_CENTREX_IMS", action: "Verificar IMPU sip:3512xxxxxxxx@ipcentrex.ims.nos.pt. Solução final via STEP 1." }
        - { ims_status: "ACTIVE_CENTREX", step4_result: "no_profile", outcome: "MISCONFIGURATION", flag: "eNUM Centrex activo mas HssSubscriberProfile ausente" }

      iot_m2m:
        - { ims_status: "NOT_APPLICABLE", step4_result: "no_profile", outcome: "CONFIRMED_IOT_DATA_ONLY", is_misconfiguration: false }
        - { ims_status: "NOT_APPLICABLE", step4_result: "profile_found", outcome: "MISCONFIGURATION", flag: "HssSubscriberProfile encontrado em número IoT/M2M" }

    with_step1_HGSDP_Perfil:
      voice_and_fixed_standard:
        - { ims_status: "ACTIVE", step1_condition: "ICS-1 ausente", outcome: "MISCONFIGURATION", flag: "eNUM=IMS ACTIVE mas HGSDP_Perfil sem ICS-1" }
        - { ims_status: "ABSENT", step1_condition: "ICS-1 presente", outcome: "MISCONFIGURATION", flag: "HGSDP_Perfil tem ICS-1 mas eNUM=ABSENT" }

      mobile_centrex_csp_note:
        - condition: "ICS-1 presente AND CSP=73"
          outcome: "POSSIBLE_MOBILE_CENTREX"
          action: "CSP=73 com ICS-1 indica possível Mobile Centrex. Confirmar no STEP 4."

      obr2_detection:
        - condition: "OBR-2 presente nos flags ODB"
          outcome: "OBR2_PROVISIONED"
          action: "Incluir na conclusão: 'OBR-2 provisionado — subscriber não habilitado para roaming.'"
          is_misconfiguration: false
          note: "Detectado em ODB flags — NÃO na LOCATION DATA."

      msc_vlr_resolution:
        description: >
          Quando LOCATION DATA contém VLR ADDRESS ou MSC NUMBER, resolver para nome de nó NOS.
          Formato HLR: '4-XXXXXXXXXXX' (prefixo '4-' é o tipo de número AXE internacional).
          Inventário completo em skill NumeracaoNOS — Secção MSC/VLR Inventory.
        action: "Resolver endereço → nome de nó e incluir no output."

      centrex_home_vs_pure:
        - { ims_status: "ACTIVE_CENTREX", step1_condition: "HGSDP_Perfil encontrado", outcome: "CONFIRMED_HOME_CENTREX", solution: "NOS Home Centrex" }
        - { ims_status: "ACTIVE_CENTREX", step1_condition: "HGSDP_Perfil ausente", outcome: "CONFIRMED_PURE_CENTREX", solution: "NOS Centrex (puro)" }

      iot_m2m:
        - { ims_status: "NOT_APPLICABLE", step1_condition: "TS11 presente", outcome: "MISCONFIGURATION", flag: "TS11 em número IoT/M2M" }
        - { ims_status: "NOT_APPLICABLE", step1_condition: "ICS-1 presente", outcome: "MISCONFIGURATION", flag: "ICS-1 em número IoT/M2M" }
        - { ims_status: "NOT_APPLICABLE", step1_condition: "BS30 ausente", outcome: "MISCONFIGURATION", flag: "BS30 ausente em número IoT/M2M" }

    with_step2B_getAuthSubscription:
      mobile_5g_sa:
        - { is_5g_sa: true, step2C_result: "profile_found", outcome: "CONFIRMED_5G_SA" }
        - { is_5g_sa: true, step2C_result: "no_profile", outcome: "MISCONFIGURATION", flag: "5G_AKA presente mas GetEpcUdmSubscription sem perfil" }
        - { is_5g_sa: false, step2C_result: "not_executed", outcome: "CONFIRMED_NON_5G_SA" }

    smart_number_multidevice:

      critical_note: >
        ADDED IN V3.6 — triggered by real analysis failure.
        Internal check is MANDATORY at every STEP 4 execution.
        maxNumberOfContacts = 1 does NOT exclude Smart Number.
        Smart Number is determined by IMPU / publicIdValue / aliasGroupId / serviceProfileId.
        All these fields MUST be analysed at STEP 4 without exception.
        Multi-device line OMITTED from output when maxNumberOfContacts = 1.
        Multi-device line included ONLY when maxNumberOfContacts > 1.

      detection_fields:
        mandatory_analysis:
          - field: "IMPU / publicIdValue"
            check: "Presença de MSISDN diferente do consultado"
            indicator: "Smart Number"
          - field: "privateUserId"
            check: "Partilhado entre múltiplos MSISDNs"
            indicator: "Smart Number"
          - field: "aliasGroupId"
            check: "Igual para múltiplos MSISDNs"
            indicator: "Smart Number confirmado"
          - field: "serviceProfileId"
            check: "Referencia MSISDN secundário"
            indicator: "Smart Number"
          - field: "maxNumberOfContacts"
            check: "Valor > 1"
            indicator: "Multi-device"
          - field: "maxNumberSessions"
            check: "Valor > 10"
            indicator: "Multi-device"

      rules:
        - id: "SMART_NUMBER_DETECTED"
          condition: "publicIdValue / IMPU contém MSISDN diferente do consultado"
          outcome: "SMART_NUMBER_DETECTED"
          action: >
            Incluir secção completa no output.
            Listar todos os MSISDNs associados.
            Identificar tipo de dispositivo se possível (ex: smart watch, tablet).

        - id: "SMART_NUMBER_CONFIRMED_ALIAS"
          condition: "aliasGroupId igual para múltiplos MSISDNs"
          outcome: "SMART_NUMBER_CONFIRMED"
          action: "Reforçar associação Smart Number no output."

        - id: "SMART_NUMBER_CONFIRMED_PROFILE"
          condition: "serviceProfileId referencia MSISDN secundário"
          outcome: "SMART_NUMBER_CONFIRMED"
          action: "Reforçar associação Smart Number via serviceProfileId."

        - id: "MULTI_DEVICE_DETECTED"
          condition: "maxNumberOfContacts > 1 OU maxNumberSessions > 10"
          outcome: "MULTI_DEVICE_DETECTED"
          action: >
            Identificar Multi-device.
            Incluir linha Multi-device no output.
            Listar dispositivos associados.

        - id: "SMART_NUMBER_NOT_MULTI_DEVICE"
          condition: "maxNumberOfContacts = 1 E MSISDN secundário presente"
          outcome: "SMART_NUMBER_CONFIRMED — MULTI_DEVICE_NOT_APPLICABLE"
          note: >
            maxNumberOfContacts = 1 NÃO exclui Smart Number.
            Smart Number é determinado por IMPU/publicIdValue/aliasGroupId/serviceProfileId
            — NÃO por maxNumberOfContacts.
            Linha Multi-device OMITIDA do output — ausência é normal e esperada.
            maxNumberOfContacts e maxNumberSessions continuam a ser analisados internamente
            mas NÃO são reportados no output quando não indicam Multi-device.

        - id: "SMART_NUMBER_AND_MULTI_DEVICE"
          condition: "MSISDN secundário presente E maxNumberOfContacts > 1"
          outcome: "SMART_NUMBER + MULTI_DEVICE"
          action: >
            Reportar Smart Number no output.
            Incluir linha Multi-device APENAS quando maxNumberOfContacts > 1.
            Omitir linha Multi-device quando maxNumberOfContacts = 1.

        - id: "NOT_DETECTED"
          condition: "Nenhum MSISDN secundário em qualquer campo"
          outcome: "NOT_DETECTED"
          action: "Incluir linha inline apenas: 'Smart Number / Multi-device : Not detected.'"
          dedicated_section: false
          recommendations: false
          note: "Ausência é normal e esperada. Não requer acção nem recomendação."

        - id: "NOT_ANALYSED"
          condition: "Perfil IMS/HSS indisponível por erro técnico de ferramenta"
          outcome: "NOT_ANALYSED"
          action: "Incluir linha inline apenas: 'Smart Number / Multi-device : Not analysed (IMS/HSS profile unavailable).'"
          dedicated_section: false
          recommendations: false
          note: "Erro de ferramenta — não é misconfiguração do subscritor. Não aplicável a IoT/M2M."

      misconfiguration_flags:
        note: >
          Estes flags aplicam-se APENAS quando MSISDN secundário existe
          mas o agente falhou na deteção.
          A ausência de linha Multi-device no output quando maxNumberOfContacts=1
          é comportamento CORRECTO — não é um flag de misconfiguração.
        flags:
          - condition: "publicIdValue / IMPU analisado apenas parcialmente E MSISDN secundário existe"
            flag: "⚠ SMART_NUMBER_OMISSION — MSISDN secundário ignorado"
            severity: "ERRO DE LÓGICA"
          - condition: "aliasGroupId presente mas não correlacionado E MSISDN secundário existe"
            flag: "⚠ aliasGroupId não correlacionado — Smart Number não detetado"
          - condition: "serviceProfileId referencia MSISDN não listado no output"
            flag: "⚠ MSISDN secundário referenciado em serviceProfileId omitido"

      output_template:
        when_detected: |
          ── SMART NUMBER / MULTI-DEVICE ──────────────────────────
          IMPU (primary)       : tel:+351XXXXXXXXX
          IMPU (secondary)     : tel:+351YYYYYYYYY  ← Smart Number
          privateUserId        : [value — shared]
          aliasGroupId         : [value — equal for both MSISDNs]
          serviceProfileId     : [value]

          ⚠ SMART NUMBER DETECTED
             Associated MSISDNs:
             - [primary MSISDN]    → primary device (smartphone)
             - [secondary MSISDN]  → associated device (e.g.: smart watch)

          [Multi-device : Yes (maxNumberOfContacts=[value])]
            ↑ Include ONLY if maxNumberOfContacts > 1. Omit entirely otherwise.
          ─────────────────────────────────────────────────────────
        output_rules:
          multi_device_line:
            include_when: "maxNumberOfContacts > 1"
            omit_when: "maxNumberOfContacts = 1"
            note: >
              maxNumberOfContacts e maxNumberSessions são campos de análise interna
              OBRIGATÓRIA em cada execução do STEP 4.
              NÃO são reportados no output quando não indicam Multi-device.
              Ausência de Multi-device é normal e esperada — não requer menção.
        when_not_detected: "Smart Number / Multi-device : Not detected."
        when_not_analysed: "Smart Number / Multi-device : Not analysed (IMS/HSS profile unavailable)."


# ═══════════════════════════════════════════════════════════════════════════════
# SECÇÃO 4 — LOOKUP STEPS
# ═══════════════════════════════════════════════════════════════════════════════

  lookup_steps:

    steps:

      - id: STEP1_HGSDP_Perfil
        tool: "HGSDP_Perfil"
        domain: "2G/CS — HLR/CUDB"
        always_execute: true
        prerequisite: "PRE-2 (FGNTP) confirmado NOS AND PRE-3 (eNUM) executado."
        actions_if_connected:
          - "Reportar MSC/VLR address, IMSI, estado CS"
          - "Resolver VLR ADDRESS / MSC NUMBER → nome de nó NOS via inventário em skill NumeracaoNOS"
          - "Analisar SUD: TS, BS, SS, ODB, CAMEL, CF, Barring, ICS, CSP/OICK"
          - "CSP=73 + ICS-1 → possível Mobile Centrex → confirmar STEP 4"
          - "Verificar flags ODB para OBR-2 → se presente: nota na conclusão"
          - "Aplicar enum_correlations.with_step1_HGSDP_Perfil"
        conditions:
          if_ICS1_present_then_execute: "STEP2_MTAS"
          if_mobile_and_connected_then_execute: "STEP2B_getAuthSubscription"
        centrex_determination:
          - { condition: "IMS_STATUS = ACTIVE_CENTREX AND HGSDP encontrado", solution: "NOS Home Centrex" }
          - { condition: "IMS_STATUS = ACTIVE_CENTREX AND HGSDP ausente", solution: "NOS Centrex (puro)" }
        iot_m2m_expected: ["BS30 presente", "TS11 ausente", "ICS-1 ausente"]
        iot_m2m_flag_if_found: ["TS11 → MISCONFIGURATION", "ICS-1 → MISCONFIGURATION", "BS30 ausente → MISCONFIGURATION"]

      - id: STEP2_MTAS
        tool: "MTAS"
        domain: "IMS/VoLTE — MTAS"
        execute_when: { ICS1_present_in_STEP1: true }
        actions:
          - "Recuperar IMPU, IMPI, iFC, CF, CW, CLIR, Barring, VoWiFi, SRVCC"
          - "Cross-reference vs HGSDP_Perfil — flag discrepâncias"
        mobile_centrex_note: "MTAS pode retornar dados limitados para Mobile Centrex — pode ser esperado."
        not_applicable: ["iot_m2m", "centrex_home_fixed", "centrex_pure_fixed"]

      - id: STEP2B_getAuthSubscription
        tool: "getAuthSubscription"
        domain: "5G SA — Authentication"
        execute_when: { STEP1_profile_found: true, number_type: "mobile" }
        result_rules:
          - { condition: "authenticationMethod = '5G_AKA'", register: "IS_5G_SA = true", action: "Executar STEP2C" }
          - { condition: "authenticationMethod ≠ '5G_AKA' ou ausente", register: "IS_5G_SA = false", action: "Continuar para STEP3" }
        not_applicable: ["fixed_geographic", "centrex_home_fixed", "centrex_pure_fixed", "special", "iot_m2m"]

      - id: STEP2C_GetEpcUdmSubscription
        tool: "GetEpcUdmSubscription"
        execute_when: { IS_5G_SA: true }
        registration_state_logic:
          - { locationState: "UNKNOWN", purgeFlag: false, state: "Registered in 5G SA" }
          - { locationState: "LOCATED", purgeFlag: true, state: "Registered in 4G/LTE" }
          - { locationState: "LOCATED", purgeFlag: false, state: "AMBIGUOUS — flag" }
          - { locationState: "UNKNOWN", purgeFlag: true, state: "MISCONFIGURATION — flag" }
        actions_if_profile_found:
          - "Apresentar perfil UDM 5G SA — ver skill NumeracaoNOS 2C.4"
          - "Resolver AMF UUID → nome/site via skill NumeracaoNOS 2C.2"
          - "Resolver SMF UUID → nome/site via skill NumeracaoNOS 2C.3"
          - "Continuar para STEP3"
        actions_if_no_profile:
          - "Flag MISCONFIGURATION: 5G_AKA presente mas UDM ausente"
          - "Continuar para STEP3"

      - id: STEP3_HSS
        tool: "HSS"
        always_execute: true
        actions_if_connected:
          - "Reportar MME address, TAI, estado EPS"
          - "Reportar roamingRestriction, epsTenantId e epsRoamingAllowed se presentes"
          - "Aplicar EPS Roaming Interpretation Chain obrigatoriamente quando roamingRestriction presente"
        eps_roaming_interpretation_chain:
          description: >
            roamingRestriction: true NÃO significa roaming bloqueado.
            Indica que um perfil de restrição está aplicado — análise adicional obrigatória.
            O parâmetro definitivo é epsRoamingAllowed — NÃO roamingRestriction.
          step1:
            field: "epsTenantId"
            present: "Restrições específicas de tenant aplicadas — analisar perfil de tenant no HSS"
            absent: "Restrições standard de operador HSS aplicadas"
          step2:
            field: "epsRoamingAllowed"
            true: "✅ Roaming permitido ao nível EPS"
            false: "⛔ Roaming totalmente bloqueado ao nível EPS"
          definitive_parameter: "epsRoamingAllowed"
          output_format: |
            roamingRestriction  : [true → restriction profile applied | false → no restriction]
            epsTenantId         : [value | ausente — restrições standard HSS aplicadas]
            epsRoamingAllowed   : [true → roaming permitido | false → roaming totalmente bloqueado]
            Conclusão EPS       : [Roaming permitido ao nível EPS | Roaming totalmente bloqueado ao nível EPS]

      - id: STEP4_HssSubscriberProfile
        tool: "HssSubscriberProfile"
        always_execute: true
        mandatory: true
        mobile_centrex_detection:
          trigger_conditions:
            - "IMPI contém '@ipcentrex.ims.nos.pt'"
            - "Service Profile = 'BW_MobileCentrex_Active'"
          action_if_triggered: "Reclassificar para NOS Mobile Centrex. Executar STEP 6."
        actions_if_profile_found:
          - "Reportar IMPU, IMPI, Service Profile, estado registo IMS"
          - "Verificar IMPI para reclassificação Mobile Centrex"
          - "Reportar iFC, serviços IMS activos, roamingAllowed"
          - "Cross-reference vs todos os STEPs anteriores"
          - "Aplicar enum_correlations.with_step4_HssSubscriberProfile"
          - "Listar TODOS os IMPU / publicIdValue presentes no perfil"
          - "Verificar privateUserId e aliasGroupId para associação Smart Number"
          - "Verificar serviceProfileId para referência a MSISDN secundário"
          - "Verificar maxNumberOfContacts e maxNumberSessions para Multi-device (análise interna obrigatória)"
          - "Aplicar enum_correlations.smart_number_multidevice"
          - >
            Output Smart Number / Multi-device:
            SE detetado → incluir secção completa com template e todos os MSISDNs associados.
            Linha Multi-device APENAS se maxNumberOfContacts > 1 — omitir se maxNumberOfContacts = 1.
            SE não detetado → incluir apenas linha inline 'Smart Number / Multi-device : Not detected.'
            SE perfil IMS/HSS indisponível → 'Smart Number / Multi-device : Not analysed (IMS/HSS profile unavailable).'
            Ausência é normal — sem secção dedicada, sem recomendações.
        smart_number_critical_note: >
          maxNumberOfContacts = 1 NÃO exclui Smart Number.
          Smart Number é determinado por IMPU / publicIdValue / aliasGroupId / serviceProfileId.
          Todos estes campos DEVEM ser analisados sem excepção.
          Linha Multi-device OMITIDA do output quando maxNumberOfContacts = 1.
          Linha Multi-device incluída APENAS quando maxNumberOfContacts > 1.
        actions_if_no_profile:
          - "Flag explícito: HssSubscriberProfile ausente"
          - "Se ICS-1 presente → flag misconfiguration"
          - "Se EPS activo → flag misconfiguration"
          - "Se IMS_STATUS=ACTIVE_CENTREX → flag misconfiguration"
          - "Para não-IoT/M2M: incluir linha inline 'Smart Number / Multi-device : Not analysed (IMS/HSS profile unavailable).'"
        iot_m2m_note: "HssSubscriberProfile ausente = ESPERADO para IoT/M2M. Smart Number não aplicável."

      - id: STEP5_SubsInfoByIMPU
        tool: "SubsInfoByIMPU"
        execute_when: { STEP1_no_profile: true, STEP3_no_profile: true, STEP4_no_profile: true }
        query_format:
          standard: "tel:+351XXXXXXXXX"
          centrex_fixed: "sip:3512xxxxxxxx@ipcentrex.ims.nos.pt"
          iot: "tel:+35149XXXXXXXXXX"

      - id: STEP6_BwGetUserInfo
        tool: "BwGetUserInfo"
        execute_for: ["fixed_voice_BroadSoft", "mobile_BroadSoft", "centrex_home_fixed", "centrex_pure_fixed", "mobile_centrex"]
        mobile_centrex_expected: "PadraoMovel activo"
        not_applicable: ["iot_m2m"]

    final_conclusion_rule:
      output_template_reference: "skill NumeracaoNOS — OUTPUT TEMPLATE — Standard Response Format (Sections 0–15)"
      final_response_must_include:
        - "Solução NOS confirmada — NOS Mobile Centrex se reclassificado no STEP 4"
        - "Se OBR-2: 'OBR-2 provisionado — subscriber não habilitado para roaming'"
        - "Perfil HGSDP_Perfil incluindo VLR/MSC ADDRESS resolvido para nome de nó NOS"
        - "Perfil MTAS (STEP 2)"
        - "Resultado getAuthSubscription IS_5G_SA (STEP 2B)"
        - "Perfil GetEpcUdmSubscription (STEP 2C se 5G SA)"
        - "Perfil HSS incluindo EPS roaming chain: roamingRestriction → epsTenantId → epsRoamingAllowed (STEP 3)"
        - "Perfil HssSubscriberProfile: IMPI, Service Profile, roamingAllowed (STEP 4)"
        - >
          Smart Number / Multi-device: incluir APENAS se detetado no STEP 4.
          Se detetado → secção completa com todos os MSISDNs associados e tipo de dispositivo.
          Linha Multi-device APENAS se maxNumberOfContacts > 1 — omitir se = 1.
          Se não detetado → linha inline apenas no output do STEP 4. Sem secção dedicada. Sem recomendações.
          Se IMS/HSS indisponível → linha inline 'Smart Number / Multi-device : Not analysed (IMS/HSS profile unavailable).'
          Ausência é normal e não requer acção.
        - "Perfil BwGetUserInfo — PadraoMovel para Mobile Centrex (STEP 6)"
        - "Todas as anomalias e misconfigurations"


