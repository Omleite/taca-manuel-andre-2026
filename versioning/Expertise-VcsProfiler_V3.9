# SECÇÃO 8 — FIXED VS MOBILE RULES
# ═══════════════════════════════════════════════════════════════════════════════

  fixed_vs_mobile_rules:
    default_rule:
      starts_with: "3512"
      classification: "fixed"
      expected_mobile_profile_in_HLR: false
    implications:
      - "getAuthSubscription e GetEpcUdmSubscription NÃO aplicáveis a números fixos"
      - "Centrex puro: HGSDP_Perfil ausente = ESPERADO"
    home_service_exception:
      oicks: ["20", "21", "22", "23", "25", "26"]
      rule: "HOME 2G mobile — não flaggear."
    centrex_distinction_rule:
      fixed_ACTIVE_CENTREX_with_HGSDP: "NOS Home Centrex"
      fixed_ACTIVE_CENTREX_without_HGSDP: "NOS Centrex (puro)"
    mobile_centrex_rule: >
      Mobile Centrex usa número móvel (9xx) com IMS_STATUS = ACTIVE.
      Reclassificação para NOS Mobile Centrex APENAS no STEP 4:
      IMPI contém @ipcentrex.ims.nos.pt OU Service Profile = BW_MobileCentrex_Active.


# ═══════════════════════════════════════════════════════════════════════════════
# SECÇÃO 9 — MISCONFIGURATION PATTERNS
# ═══════════════════════════════════════════════════════════════════════════════

  misconfiguration_patterns:

    - { symptom: "Análise técnica sem FGNTP", severity: "CRÍTICA", consequence: "Diagnóstico inválido." }
    - { symptom: "Subscriber não consegue receber chamadas", likely_root_causes: ["CFU/CFNRC activo", "BAIC provisionado", "Registo MSC errado"] }
    - { symptom: "Subscriber não consegue fazer chamadas", likely_root_causes: ["BAOC/ODB barring", "TS11 em falta", "CAMEL SCP inacessível"] }
    - { symptom: "SMS não funciona", likely_root_causes: ["TS20/TS21/TS22 em falta", "SMS barring", "CAMEL MO-SMS falhou"] }
    - { symptom: "VoLTE não funciona", likely_root_causes: ["ICS-1 ausente", "CSP não 79/80", "MTAS misconfiguration", "HssSubscriberProfile ausente", "eNUM ACTIVE mas ICS-1 ausente"] }
    - { symptom: "5G SA não funciona", likely_root_causes: ["authenticationMethod ≠ 5G_AKA", "GetEpcUdmSubscription sem perfil", "Network slice/DNN/QoS incorrectos", "UUID AMF/SMF desconhecido"] }
    - symptom: "Smart Number não detetado pelo agente"
      note: "Aplica-se APENAS quando MSISDN secundário existe mas o agente não detetou."
      likely_root_causes:
        - "publicIdValue não analisado no STEP 4"
        - "aliasGroupId presente mas não correlacionado"
        - "serviceProfileId não verificado para MSISDN secundário"
        - "privateUserId não verificado"
        - "enum_correlations.smart_number_multidevice não aplicadas"
        - "maxNumberOfContacts=1 erroneamente usado como critério exclusivo"
    - symptom: "MSISDN secundário omitido no output"
      note: "Aplica-se APENAS quando MSISDN secundário existe mas foi omitido."
      likely_root_causes:
        - "Análise limitada ao MSISDN principal"
        - "publicIdValue ignorado no processamento do perfil IMS/HSS"
        - "aliasGroupId não correlacionado com MSISDN secundário"
    - { symptom: "Multi-device / Smart Number service não funciona", likely_root_causes: ["HssSubscriberProfile ausente/incompleto", "iFC em falta", "IMPU/IMPI incorrectos"] }
    - { symptom: "Mobile Centrex não funciona", likely_root_causes: ["ICS-1 ausente", "IMPI domínio errado", "Service Profile não BW_MobileCentrex_Active", "BwGetUserInfo PadraoMovel não activo ou Suspended", "IMS Unregistered"] }
    - { symptom: "Mobile Centrex identificado incorrectamente como VoLTE", likely_root_causes: ["Classificação preliminar PRE-4 = VoLTE — reclassificação apenas no STEP 4 via IMPI @ipcentrex ou Service Profile"] }
    - { symptom: "Subscriber inacessível quando fora de Portugal", likely_root_causes: ["OBR-2 provisionado nos flags ODB — HLR rejeita registos estrangeiros"], conclusion_note: "OBR-2 provisionado — subscriber não habilitado para roaming.", not_a_misconfiguration: true }
    - { symptom: "Chamadas recebidas bloqueadas em roaming", likely_root_causes: ["BICROAM activo"] }
    - symptom: "Roaming bloqueado a nível 4G/EPS"
      likely_root_causes:
        - "epsRoamingAllowed: false no HSS EPS — parâmetro definitivo de bloqueio"
        - "roamingRestriction: true com epsRoamingAllowed: false — bloqueio total confirmado"
      note: >
        roamingRestriction: true por si só NÃO significa roaming bloqueado.
        Verificar sempre epsTenantId (se presente → restrições de tenant)
        e epsRoamingAllowed (parâmetro definitivo).
    - symptom: "Roaming EPS com restrições parciais (tenant)"
      likely_root_causes:
        - "roamingRestriction: true + epsTenantId presente → restrições específicas de tenant aplicadas"
        - "Verificar perfil de tenant no HSS para lista de operadores permitidos/bloqueados"
    - { symptom: "Roaming bloqueado a nível IMS", likely_root_causes: ["roamingAllowed: false no IMS/HSS"] }
    - { symptom: "Serviço de dados não funciona", likely_root_causes: ["BS30 ausente", "APN não provisionado", "QoS mal configurado", "ODB PS barring"] }
    - { symptom: "Call forwarding inesperado", likely_root_causes: ["CFU/CFB/CFNRY/CFNRC com destino errado"] }
    - { symptom: "Chamadas internacionais bloqueadas", likely_root_causes: ["BOIC/BOIC-exHC", "ODB international barring"] }
    - { symptom: "Conflito AMSISDN", likely_root_causes: ["AMSISDN = MSISDN"] }
    - { symptom: "eNUM dessincronizado", likely_root_causes: ["eNUM ACTIVE mas HssSubscriberProfile ausente", "eNUM ABSENT mas HssSubscriberProfile presente"] }
    - { symptom: "Centrex fixo sem voz", applicable_to: "ACTIVE_CENTREX", likely_root_causes: ["HssSubscriberProfile ausente", "IMPU errado", "iFC em falta", "IMS Unregistered", "BwGetUserInfo Suspended"] }
    - { symptom: "Centrex IMPU errado", likely_root_causes: ["Domínio errado (ims.nos.pt vs ipcentrex.ims.nos.pt)", "Número IMPU ≠ MSISDN"] }
    - { symptom: "IoT/M2M sem dados PS", applicable_to: "iot_m2m", likely_root_causes: ["BS30 ausente", "APN M2M errado", "ODB PS barring", "QoS inadequado", "EPS incompleto"] }
    - { symptom: "IoT/M2M com voz inesperada", applicable_to: "iot_m2m", likely_root_causes: ["TS11 presente", "ICS-1 presente", "HssSubscriberProfile encontrado"] }
    - { symptom: "IoT/M2M não registado", applicable_to: "iot_m2m", likely_root_causes: ["IMSI não provisionado", "SIM inativo", "APN em falta", "NB-IoT/LTE-M não suportado", "Duty cycle baixo (pode ser normal)"] }