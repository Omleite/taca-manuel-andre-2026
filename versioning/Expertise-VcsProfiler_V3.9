      - { type: "fixed_geographic", prefix: "2xx", portability: "NOS", ims_status: "ACTIVE_CENTREX", hgsdp: "AUSENTE", solution: "NOS Centrex (puro)", platform: "IMS IP Centrex (ipcentrex.ims.nos.pt)", note: "HGSDP ausente = ESPERADO" }
